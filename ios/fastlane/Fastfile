default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Build the Flutter IPA
    Dir.chdir("../..") do
      sh("flutter build ipa --release")
    end

    # App Store Connect API credentials — all env-driven so key rotations
    # don't require code changes. Defaults are the current production key.
    key_id     = ENV["APP_STORE_CONNECT_KEY_ID"]     || "S33J7V6RL3"
    issuer_id  = ENV["APP_STORE_CONNECT_ISSUER_ID"]
    key_file   = File.expand_path("~/private_keys/AuthKey_#{key_id}.p8")

    raise "APP_STORE_CONNECT_ISSUER_ID is not set. Export it from ~/.zshrc." if issuer_id.nil? || issuer_id.empty?
    raise "App Store Connect private key not found at #{key_file}." unless File.exist?(key_file)

    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: key_file,
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "../build/ios/ipa/Balam.AI.ipa",
      skip_waiting_for_build_processing: true,
    )
  end
end
